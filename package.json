{
  "name": "anchor",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "schema": "tsx src/graphql/print-schema.ts",
    "codegen": "pnpm run schema && graphql-codegen",
    "codegen:watch": "graphql-codegen --watch",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@mui/material-nextjs": "^9.0.1",
    "@neondatabase/serverless": "^1.1.0",
    "@pothos/core": "^4.12.0",
    "@pothos/plugin-prisma": "^4.14.3",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@urql/next": "^2.0.0",
    "graphql": "^16.14.0",
    "graphql-yoga": "^5.21.0",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "urql": "^5.0.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.0",
    "@graphql-codegen/client-preset": "^6.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
