generator client {
  provider = "prisma-client-js"
}

generator pothos {
  provider          = "prisma-pothos-types"
  generateDatamodel = "true"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  CHECKING
  SAVINGS
  MONEY_MARKET
  CD
  BROKERAGE
  FOUR_OH_ONE_K
  ROTH_IRA
  TRADITIONAL_IRA
  HSA
  FIVE_TWO_NINE
  CRYPTO
  CREDIT_CARD
  CHARGE_CARD
}

enum AccountSource {
  PLAID
  MANUAL
}

enum PerkPeriod {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  QUADRENNIAL
}

enum ResetType {
  CALENDAR
  ANNIVERSARY
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  budgetStartYear  Int?
  budgetStartMonth Int?

  creditCards        CreditCard[]
  incomeSources      IncomeSource[]
  budgetGroups       BudgetGroup[]
  savingsAccounts    SavingsAccount[]
  savingsGoals       SavingsGoal[]
  surplusAllocations SurplusAllocation[]
  subscriptions      Subscription[]
  plaidItems         PlaidItem[]
  accounts           Account[]
  splitPartner       SplitPartner?
  splitExpenses      SplitExpense[]
  splitSettlements   SplitSettlement[]
  splitExclusions    SubscriptionSplitExclusion[]
}

model IncomeSource {
  id       String  @id @default(cuid())
  userId   String
  label    String
  sub      String?
  amount   Decimal @db.Decimal(10, 2)
  position Int     @default(0)

  user User @relation(fields: [userId], references: [id])
}

model BudgetGroup {
  id         String           @id @default(cuid())
  userId     String
  label      String
  icon       String
  position   Int              @default(0)
  user       User             @relation(fields: [userId], references: [id])
  categories BudgetCategory[]
}

model BudgetCategory {
  id       String         @id @default(cuid())
  groupId  String
  label    String
  icon     String
  budget   Decimal        @db.Decimal(10, 2) @default(0)
  position Int            @default(0)
  group    BudgetGroup    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  spends   MonthlySpend[]
  monthlyBudgets MonthlyBudget[]
  lineItems BudgetLineItem[]
}

model MonthlyBudget {
  id         String         @id @default(cuid())
  categoryId String
  year       Int
  month      Int
  budget     Decimal        @db.Decimal(10, 2)
  category   BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, year, month])
}

model MonthlySpend {
  id         String         @id @default(cuid())
  categoryId String
  year       Int
  month      Int
  amount     Decimal        @db.Decimal(10, 2)
  category   BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, year, month])
}

/// Optional finer-grained breakdown of a BudgetCategory (e.g. Utilities -> water, electricity).
/// A category with no line items behaves exactly as before; once it has any,
/// the category's own MonthlyBudget/MonthlySpend rows are kept in sync (sum of lines)
/// by the mutations that edit line items, so existing category-level reads stay correct.
model BudgetLineItem {
  id             String              @id @default(cuid())
  categoryId     String
  label          String
  icon           String
  budget         Decimal             @db.Decimal(10, 2) @default(0)
  position       Int                 @default(0)
  category       BudgetCategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  spends         MonthlyLineSpend[]
  monthlyBudgets MonthlyLineBudget[]
}

model MonthlyLineBudget {
  id         String         @id @default(cuid())
  lineItemId String
  year       Int
  month      Int
  budget     Decimal        @db.Decimal(10, 2)
  lineItem   BudgetLineItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)

  @@unique([lineItemId, year, month])
}

model MonthlyLineSpend {
  id         String         @id @default(cuid())
  lineItemId String
  year       Int
  month      Int
  amount     Decimal        @db.Decimal(10, 2)
  lineItem   BudgetLineItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)

  @@unique([lineItemId, year, month])
}

model SavingsAccount {
  id            String                @id @default(cuid())
  userId        String
  label         String
  accountType   String
  icon          String
  monthly       Decimal               @db.Decimal(10, 2) @default(0)
  annualLimit   Decimal?              @db.Decimal(10, 2)
  position      Int                   @default(0)
  user          User                  @relation(fields: [userId], references: [id])
  contributions MonthlyContribution[]
  goal          SavingsGoal?          @relation("LinkedAccount")
}

model MonthlyContribution {
  id        String         @id @default(cuid())
  accountId String
  year      Int
  month     Int
  amount    Decimal        @db.Decimal(10, 2)
  account   SavingsAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, year, month])
}

model SavingsGoal {
  id              String              @id @default(cuid())
  userId          String
  name            String
  icon            String
  target          Decimal?            @db.Decimal(10, 2)
  base            Decimal             @db.Decimal(10, 2) @default(0)
  targetYear      Int?
  targetMonth     Int?
  linkedAccountId String?             @unique
  user            User                @relation(fields: [userId], references: [id])
  linkedAccount   SavingsAccount?     @relation("LinkedAccount", fields: [linkedAccountId], references: [id])
  allocations     SurplusAllocation[]
}

model SurplusAllocation {
  id     String      @id @default(cuid())
  goalId String
  userId String
  year   Int
  month  Int
  amount Decimal     @db.Decimal(10, 2)
  goal   SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id])

  @@unique([goalId, year, month])
}

model CreditCard {
  id       String  @id @default(cuid())
  userId   String
  name     String
  issuer   String
  lastFour   String?
  openedDate DateTime? @db.Date
  design String? // slug e.g. "chase-sapphire-preferred"

  user  User   @relation(fields: [userId], references: [id])
  perks Perk[]
}

model Perk {
  id               String     @id @default(cuid())
  creditCardId     String
  name             String
  totalAmount      Decimal    @db.Decimal(10, 2)
  period             PerkPeriod
  resetType          ResetType  @default(CALENDAR)
  enrollmentRequired Boolean    @default(false)
  notes              String?
  createdAt          DateTime   @default(now())

  creditCard CreditCard   @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  perkCredit PerkCredit[]
}

model PerkCredit {
  id           String   @id @default(cuid())
  perkId       String
  amount       Decimal  @db.Decimal(10, 2)
  date         DateTime @db.Date
  description  String?
  createdAt    DateTime @default(now())

  perk Perk @relation(fields: [perkId], references: [id], onDelete: Cascade)
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  name      String
  cat       String
  icon      String
  cost      Decimal  @db.Decimal(10, 2)
  period    String
  day       Int
  renewM    Int?
  cardId    String
  plan      String?
  paused        Boolean  @default(false)
  cancelPending Boolean  @default(false)
  shared        Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  splitExclusions SubscriptionSplitExclusion[]
}

/** A one-off "don't auto-split this subscription for this month" tombstone. */
model SubscriptionSplitExclusion {
  id             String   @id @default(cuid())
  userId         String
  subscriptionId String
  year           Int
  month          Int
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, year, month])
}

model PlaidItem {
  id              String   @id @default(cuid())
  userId          String
  accessToken     String
  itemId          String   @unique
  institutionId   String?
  institutionName String
  createdAt       DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  accounts Account[]
}

model Account {
  id               String        @id @default(cuid())
  userId           String
  plaidItemId      String?
  plaidAccountId   String?
  source           AccountSource
  type             AccountType
  nick             String
  inst             String
  balance          Decimal       @db.Decimal(12, 2)
  isEmergencyFund  Boolean       @default(false)
  balanceUpdatedAt DateTime      @default(now())
  createdAt        DateTime      @default(now())

  user      User       @relation(fields: [userId], references: [id])
  plaidItem PlaidItem? @relation(fields: [plaidItemId], references: [id], onDelete: SetNull)
}

model SplitPartner {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model SplitExpense {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  month     Int
  date      String?
  desc      String
  amount    Decimal  @db.Decimal(10, 2)
  payer     String
  cat       String
  splitYou  Int
  splitThem Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model SplitSettlement {
  id          String   @id @default(cuid())
  userId      String
  year        Int
  month       Int
  date        String?
  amount      Decimal  @db.Decimal(10, 2)
  fromPayer   String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
