generator client {
  provider = "prisma-client-js"
}

generator pothos {
  provider          = "prisma-pothos-types"
  generateDatamodel = "true"
}

datasource db {
  provider = "postgresql"
}

enum PerkPeriod {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  QUADRENNIAL
}

enum ResetType {
  CALENDAR
  ANNIVERSARY
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  creditCards CreditCard[]
}

model CreditCard {
  id       String  @id @default(cuid())
  userId   String
  name     String
  issuer   String
  lastFour   String?
  openedDate DateTime? @db.Date
  design String? // slug e.g. "chase-sapphire-preferred"

  user  User   @relation(fields: [userId], references: [id])
  perks Perk[]
}

model Perk {
  id               String     @id @default(cuid())
  creditCardId     String
  name             String
  totalAmount      Decimal    @db.Decimal(10, 2)
  period             PerkPeriod
  resetType          ResetType  @default(CALENDAR)
  enrollmentRequired Boolean    @default(false)
  notes              String?
  createdAt          DateTime   @default(now())

  creditCard CreditCard   @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  perkCredit PerkCredit[]
}

model PerkCredit {
  id           String   @id @default(cuid())
  perkId       String
  amount       Decimal  @db.Decimal(10, 2)
  date         DateTime @db.Date
  description  String?
  createdAt    DateTime @default(now())

  perk Perk @relation(fields: [perkId], references: [id])
}
